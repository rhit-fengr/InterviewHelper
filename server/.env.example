# Server environment variables
# Copy this file to .env and fill in your values

# AI provider selection: openai | gemini
AI_PROVIDER=openai

# OpenAI API Key (required when AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model overrides
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-flash

# Stripe (required for billing features)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICE_ID=price_your_monthly_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Server port (default: 4000)
PORT=4000

# Allowed CORS origins (comma-separated or * for all; restrict in production)
# Example: CORS_ORIGIN=https://your-app.com
CORS_ORIGIN=*
